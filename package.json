{
  "name": "mykstars",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run check:style && npm run check:articles && npm run check:fresh && npm run check:profiles && npm run check:edition && npm run check:media",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "check:style": "node --import tsx scripts/check-style.ts",
    "check:articles": "node --import tsx scripts/check-articles.ts",
    "check:fresh": "node --import tsx scripts/check-freshness.ts",
    "check:profiles": "node --import tsx scripts/check-profiles.ts",
    "check:edition": "node --import tsx scripts/check-edition.ts",
    "check:media": "node --import tsx scripts/check-media.ts",
    "check:generated": "node --import tsx scripts/check-generated.ts",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test:backend": "NODE_OPTIONS=--conditions=react-server NODE_PATH=node_modules/next/dist/compiled node --import tsx --test tests/backend/*.test.ts",
    "verify": "npm run prebuild && npm run check:generated && npm run typecheck && npm run lint && npm run test:backend",
    "gen:edition": "node --import tsx scripts/generate-edition.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.2",
    "@vercel/analytics": "^2.0.1",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  }
}
